  "annotations": {
    "list": [
      {
        "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
        "enable": true,
        "expr": "changes(robot_alert_total[1m]) > 0",
        "hide": false,
        "iconColor": "red",
        "name": "Alert Events",
        "step": "60s",
        "titleFormat": "Alert fired",
        "textFormat": "Robot {{robot_id}} — {{alert_type}} ({{severity}})",
        "type": "graph"
      }
    ]
  },
  "description": "Robot fleet telemetry and alert monitoring",
