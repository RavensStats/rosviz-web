# =============================================================
#  ROSViz Web — Environment Configuration Reference
#  Copy to .env and edit before running docker compose up.
# =============================================================

# ── Fleet configuration ────────────────────────────────────
# Robot model determines the footprint used for collision thresholds.
# Options: burger | waffle | waffle_pi
TURTLEBOT3_MODEL=waffle

# Number of simulated robots (0-based: tb3_0, tb3_1, ...)
NUM_ROBOTS=3

# ── Collision detection ────────────────────────────────────
# Base threshold is auto-computed from robot footprint + margin.
# Set ALERT_SCAN_MIN_M to override the auto-computed value entirely.
# ALERT_SCAN_MIN_M=0.266        # metres — overrides footprint-based default
ALERT_SCAN_MARGIN_M=0.05        # metres added to footprint corner radius
ALERT_SCAN_REACTION_S=0.5       # velocity lookahead window (seconds)

# ── Velocity limits ────────────────────────────────────────
ALERT_VEL_LINEAR_MAX=0.50       # m/s  — triggers VELOCITY_EXCEEDED
ALERT_VEL_ANGULAR_MAX=2.00      # rad/s — triggers VELOCITY_EXCEEDED

# ── Connection watchdog ────────────────────────────────────
ALERT_CONN_TIMEOUT_S=5.0        # seconds of silence before CONNECTION_LOSS alert

# ── Battery thresholds ─────────────────────────────────────
ALERT_BATTERY_PCT_MIN=20.0      # percent — triggers LOW_BATTERY
ALERT_BATTERY_VOLT_MIN=10.5     # volts   — triggers LOW_BATTERY

# ── IMU thresholds ─────────────────────────────────────────
ALERT_IMPACT_ACCEL_MS2=8.0      # m/s² horizontal acceleration — triggers IMPACT_DETECTED
ALERT_TILT_DEG=20.0             # degrees roll/pitch max       — triggers TILT_WARNING

# ── Motor stall detection ──────────────────────────────────
ALERT_STALL_DURATION_S=2.0      # seconds under active cmd before MOTOR_STALL alert

# ── Geofence bounding box ──────────────────────────────────
# Robots outside this box trigger GEOFENCE_BREACH.
ALERT_GEOFENCE_X_MIN=-5.0       # metres
ALERT_GEOFENCE_X_MAX=5.0
ALERT_GEOFENCE_Y_MIN=-5.0
ALERT_GEOFENCE_Y_MAX=5.0

# ── Alert history persistence ──────────────────────────────
# Path inside the ros-stack container (mounted from alert-data Docker volume).
ALERT_HISTORY_FILE=/data/alert_history.json

# ── Alert delivery — generic webhook ──────────────────────
# POST destination for Grafana unified alerting.
# Supports Slack, PagerDuty, or any HTTP endpoint.
# Default is a Prometheus health-check URL (effectively a no-op).
# Example (Slack):  https://hooks.slack.com/services/T.../B.../...
ALERT_WEBHOOK_URL=http://prometheus:9090/-/healthy

# ── Alert delivery — Discord ───────────────────────────────
# Native Grafana Discord contact point (Grafana 10+).
# Create a webhook at: Discord server → Settings → Integrations → Webhooks
# Leave empty to disable Discord notifications.
# Example: https://discord.com/api/webhooks/1234567890/abcdef...
DISCORD_WEBHOOK_URL=

# ── Grafana credentials ────────────────────────────────────
# Change these in any environment accessible beyond localhost.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
